  "keyFeatures": [
    "JWT-based authentication with email verification",
    "Role-based access control (Admin & User roles)",
    "Multi-type bank accounts (Savings & Checking)",
    "Secure money transfers and deposits",
    "Automated interest accrual for savings accounts",
    "Loyalty points system with service redemption",
    "Admin approval workflow for account creation",
    "Transaction history and cancellation",
    "Rate limiting and security middleware",
    "Currency conversion support"
  ],
